[user]
	name = ThBuKj
	email = thomas.bubere@hotmail.com

[core]
    editor = micro      # Använd Micro för commits och rebase!
    pager = less -FRX   # Gör så att korta loggar inte rensar skärmen

[init]
    defaultBranch = main  # Så du slipper döpa om 'master' till 'main' jämt

[push]
    autoSetupRemote = true  # Slipp skriva "git push --set-upstream origin..."

[pull]
    rebase = true  # Håller historiken ren (slipper "Merge branch..." commits)

[alias]
#    st = status
#    co = checkout
#    ci = commit
#    br = branch
#    unstage = reset HEAD --
#    last = log -1 HEAD
    # Denna nedan är guld värd. Ger dig en snygg graf över historiken:
	lg = log --oneline --graph --decorate --all
	undo = reset --soft HEAD~1

[color]
    ui = always
